# ── Supabase ─────────────────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Clé service (server-side uniquement, jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Chiffrement des données sensibles ─────────────────────────────────────────
# Même clé que l'app Railway pour permettre la migration des données existantes
ENCRYPTION_KEY=votre-cle-32-octets-en-hex

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

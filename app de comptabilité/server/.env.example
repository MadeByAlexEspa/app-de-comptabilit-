PORT=3001
CLIENT_URL=http://localhost:5173

# Chemin vers le dossier de données (contient master.db, compta.db, {id}.db)
# En local : laisser vide (défaut : server/data/)
# Sur Railway : créer un volume monté sur /app/data et mettre DATA_DIR=/app/data
DATA_DIR=

# Auth — REQUIRED in production. Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=<replace-with-at-least-64-random-bytes>

# Set to "production" in prod to hide internal error details and skip demo seed
NODE_ENV=development

# Back-office admin credentials (indépendant de la base users)
ADMIN_USERNAME=admin
ADMIN_CODE=<code-à-définir>
